<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/discord_dark_base">

    <!-- Top Toolbar Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/channel_header"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp"
        android:background="@color/discord_dark_alt"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="10dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/discord_text_primary"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Channel Settings"
            android:textColor="@android:color/white"
            android:textSize="17sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp"
            app:layout_constraintStart_toEndOf="@id/btn_back"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/btn_save"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SAVE"
            android:textColor="@color/discord_green"
            android:textSize="14sp"
            android:textStyle="bold"
            android:padding="8dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
        android:id="@+id/toolbar_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/discord_divider"
        app:layout_constraintTop_toBottomOf="@id/channel_header" />

    <!-- Main Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar_divider"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Channel Name Input Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_rounded_deep"
                android:backgroundTint="@color/discord_dark_alt">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CHANNEL NAME"
                    android:textColor="@color/discord_text_muted"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/et_channel_name"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="@android:color/transparent"
                    android:text="# general-chat"
                    android:textColor="@color/discord_text_primary"
                    android:textSize="15sp"
                    android:singleLine="true" />
            </LinearLayout>

            <!-- Channel Topic Input Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_rounded_deep"
                android:backgroundTint="@color/discord_dark_alt">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CHANNEL TOPIC"
                    android:textColor="@color/discord_text_muted"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/et_channel_topic"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="40dp"
                    android:background="@android:color/transparent"
                    android:text="Welcome to the fantasy world chat!"
                    android:textColor="@color/discord_text_primary"
                    android:textSize="15sp"
                    android:inputType="textMultiLine"
                    android:maxLines="3" />
            </LinearLayout>

            <!-- SETTINGS SWITCHES -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CHANNEL SETTINGS"
                android:textColor="@color/discord_text_muted"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_rounded_deep"
                android:backgroundTint="@color/discord_dark_alt">

                <!-- Private Channel Switch -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Private Channel"
                            android:textColor="@color/discord_text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switch_private"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:thumbTint="@android:color/white"
                            app:trackTint="@color/discord_blurple" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Only selected roles and members will be able to view and send messages in this channel."
                        android:textColor="@color/discord_text_muted"
                        android:textSize="11sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/discord_divider" />

                <!-- NSFW Switch -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Age-Restricted (NSFW) Channel"
                            android:textColor="@color/discord_text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switch_nsfw"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:thumbTint="@android:color/white"
                            app:trackTint="@color/discord_blurple" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Users must confirm they are over 18 before they are able to view content in this channel."
                        android:textColor="@color/discord_text_muted"
                        android:textSize="11sp" />
                </LinearLayout>

            </LinearLayout>

            <!-- SLOWMODE COOLDOWN SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SLOWMODE COOLDOWN (SIMULATOR)"
                android:textColor="@color/discord_text_muted"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_rounded_deep"
                android:backgroundTint="@color/discord_dark_alt"
                android:padding="16dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select message cooldown delay:"
                    android:textColor="@color/discord_text_muted"
                    android:textSize="12sp"
                    android:layout_marginBottom="12dp" />

                <!-- Slowmode Cooldown chips group -->
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/cg_slowmode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleLine="false"
                    app:singleSelection="true">

                    <!-- Off chip -->
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_slowmode_off"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Off"
                        android:checked="true"
                        android:textColor="@android:color/white"
                        app:chipCornerRadius="8dp" />

                    <!-- 5s chip -->
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_slowmode_5s"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5 Seconds"
                        android:textColor="@android:color/white"
                        app:chipCornerRadius="8dp" />

                    <!-- 10s chip -->
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_slowmode_10s"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="10 Seconds"
                        android:textColor="@android:color/white"
                        app:chipCornerRadius="8dp" />

                    <!-- 30s chip -->
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_slowmode_30s"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="30 Seconds"
                        android:textColor="@android:color/white"
                        app:chipCornerRadius="8dp" />

                    <!-- 1m chip -->
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_slowmode_1m"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1 Minute"
                        android:textColor="@android:color/white"
                        app:chipCornerRadius="8dp" />

                </com.google.android.material.chip.ChipGroup>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
