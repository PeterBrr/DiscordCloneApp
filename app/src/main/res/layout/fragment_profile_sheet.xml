<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/discord_dark_elevated">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Banner & Avatar Header -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="140dp">
            
            <ImageView
                android:id="@+id/iv_banner"
                android:layout_width="match_parent"
                android:layout_height="112dp"
                android:scaleType="centerCrop"
                android:background="@color/discord_dark_alt" />
                
            <!-- Avatar overlapping banner -->
            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="16dp"
                android:background="@drawable/bg_circle_elevated"
                android:padding="4dp">
                
                <ImageView
                    android:id="@+id/iv_avatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_circle_dark" />
                    
                <View
                    android:id="@+id/v_online_status"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="-2dp"
                    android:layout_marginBottom="-2dp"
                    android:background="@drawable/bg_circle_green_bordered" />
            </FrameLayout>
        </FrameLayout>

        <!-- Profile Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_margin="16dp"
            android:background="@drawable/bg_rounded_deep">
            
            <TextView
                android:id="@+id/tv_display_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:textSize="24sp"
                android:textStyle="bold" />
                
            <TextView
                android:id="@+id/tv_username"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/discord_text_muted"
                android:textSize="14sp" />
                
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="12dp"
                android:background="@color/discord_dark_alt" />
                
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ABOUT ME"
                android:textColor="@color/discord_text_muted"
                android:textSize="12sp"
                android:textStyle="bold" />
                
            <TextView
                android:id="@+id/tv_about_me"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/discord_text_secondary"
                android:textSize="14sp" />
                
        </LinearLayout>

        <!-- Send Message Button -->
        <Button
            android:id="@+id/btn_send_message"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="24dp"
            android:text="Send Message"
            android:textAllCaps="false"
            android:backgroundTint="@color/discord_blurple"
            android:textColor="@android:color/white"
            app:icon="@android:drawable/ic_menu_send"
            app:iconGravity="textStart"
            app:cornerRadius="12dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
