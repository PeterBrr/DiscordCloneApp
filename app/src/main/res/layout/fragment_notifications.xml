<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/discord_dark_base">

    <!-- Header Toolbar -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/discord_dark_base"
        android:paddingHorizontal="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:text="Notifications"
            android:textColor="@color/discord_text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btn_clear_notifications"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center_vertical|end"
            android:src="@android:drawable/ic_menu_delete"
            app:tint="@color/discord_text_muted" />
    </FrameLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/discord_divider" />

    <!-- Filter Tabs Layout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:background="@color/discord_dark_base">

        <TextView
            android:id="@+id/tab_all"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="All"
            android:textColor="@color/discord_text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp"
            android:background="@drawable/bg_rounded_deep" />

        <TextView
            android:id="@+id/tab_mentions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Mentions"
            android:textColor="@color/discord_text_muted"
            android:textSize="14sp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp" />
    </LinearLayout>

    <!-- Scrollable Feed -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card 1: Mention in #general-chat -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/discord_dark_alt"
                android:padding="14dp"
                android:layout_marginBottom="12dp">

                <!-- Red accent indicator representing high-priority mention -->
                <View
                    android:layout_width="4dp"
                    android:layout_height="match_parent"
                    android:background="@color/discord_red"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Valkyrie"
                            android:textColor="@color/discord_text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" mentioned you in "
                            android:textColor="@color/discord_text_muted"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="#general-chat"
                            android:textColor="@color/discord_blurple"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="\"Yes! 8 PM EST. Make sure you bring enough potions this time... \uD83E\uDD23\""
                        android:textColor="@color/discord_text_secondary"
                        android:textSize="13sp"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fantasy World • 1h ago"
                        android:textColor="@color/discord_text_muted"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Card 2: Friend Request -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/discord_dark_alt"
                android:padding="14dp"
                android:layout_marginBottom="12dp">

                <!-- Green accent indicator representing success/positive request -->
                <View
                    android:layout_width="4dp"
                    android:layout_height="match_parent"
                    android:background="@color/discord_green"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Friend Request Received"
                        android:textColor="@color/discord_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="DoggoGamer (@doggo) sent you a friend request."
                        android:textColor="@color/discord_text_secondary"
                        android:textSize="13sp"
                        android:layout_marginBottom="10dp"/>

                    <!-- Action buttons -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btn_accept_friend"
                            style="?android:attr/buttonStyleSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:text="Accept"
                            android:textSize="12sp"
                            android:textColor="@android:color/white"
                            android:backgroundTint="@color/discord_green"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:paddingHorizontal="16dp" />

                        <Button
                            android:id="@+id/btn_decline_friend"
                            style="?android:attr/buttonStyleSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:layout_marginStart="8dp"
                            android:text="Ignore"
                            android:textSize="12sp"
                            android:textColor="@color/discord_text_primary"
                            android:backgroundTint="@color/discord_dark_base"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:paddingHorizontal="16dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Card 3: Server Invite -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/discord_dark_alt"
                android:padding="14dp">

                <!-- Blurple accent indicator representing announcement/invite -->
                <View
                    android:layout_width="4dp"
                    android:layout_height="match_parent"
                    android:background="@color/discord_blurple"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Server Invitation"
                        android:textColor="@color/discord_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Nova (@nova) invited you to join the Cyber City server."
                        android:textColor="@color/discord_text_secondary"
                        android:textSize="13sp"
                        android:layout_marginBottom="10dp"/>

                    <Button
                        android:id="@+id/btn_join_invite"
                        style="?android:attr/buttonStyleSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Join Server"
                        android:textSize="12sp"
                        android:textColor="@android:color/white"
                        android:backgroundTint="@color/discord_blurple"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:paddingHorizontal="16dp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
