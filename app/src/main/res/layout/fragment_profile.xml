<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/discord_dark_base"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="24dp">

        <!-- Banner Header -->
        <ImageView
            android:id="@+id/iv_banner"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:scaleType="centerCrop"
            android:src="@drawable/bg_rounded_deep"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Avatar Border/Circle Frame -->
        <FrameLayout
            android:id="@+id/avatar_container"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="90dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:id="@+id/iv_avatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_circle_dark"
                android:padding="4dp"
                android:scaleType="centerCrop" />

            <!-- Live Online Badge -->
            <View
                android:id="@+id/v_online_status"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="bottom|end"
                android:layout_margin="2dp"
                android:background="@drawable/bg_circle_green_bordered" />
        </FrameLayout>

        <!-- User Information -->
        <TextView
            android:id="@+id/tv_display_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginHorizontal="24dp"
            android:text="Me"
            android:textColor="@color/discord_text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/avatar_container"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_username"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:text="\@me"
            android:textColor="@color/discord_text_muted"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tv_display_name"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Status Card Container -->
        <LinearLayout
            android:id="@+id/status_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/discord_dark_alt"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:padding="12dp"
            app:layout_constraintTop_toBottomOf="@id/tv_username"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_btn_speak_now"
                app:tint="@color/discord_text_muted"
                android:layout_gravity="center_vertical"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/tv_status_message"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_gravity="center_vertical"
                android:text="Just coding things."
                android:textColor="@color/discord_text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Discord Nitro Gradient Promo Card -->
        <LinearLayout
            android:id="@+id/nitro_promo_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:padding="16dp"
            android:background="@drawable/bg_rounded_deep"
            android:backgroundTint="#7A22A5"
            app:layout_constraintTop_toBottomOf="@id/status_card"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/btn_star_big_on"
                    app:tint="#FFDF00"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Get Nitro Premium"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Unlock custom emojis, profile banners, larger uploads, and stand out in voice chats!"
                android:textColor="#E0C6EF"
                android:textSize="12sp"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btn_buy_nitro"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Learn More"
                android:textColor="#7A22A5"
                android:backgroundTint="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingHorizontal="16dp" />
        </LinearLayout>

        <!-- Settings Label -->
        <TextView
            android:id="@+id/lbl_settings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ACCOUNT SETTINGS"
            android:textColor="@color/discord_text_muted"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginStart="24dp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/nitro_promo_card"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Settings Settings Group -->
        <LinearLayout
            android:id="@+id/grp_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/discord_dark_alt"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/lbl_settings"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Item 1: Account -->
            <LinearLayout
                android:id="@+id/btn_setting_account"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:gravity="center_vertical"
                android:background="?android:attr/selectableItemBackground">
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Account"
                    android:textColor="@color/discord_text_primary"
                    android:textSize="14sp" />
                    
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/ic_media_play"
                    app:tint="@color/discord_text_muted" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/discord_divider" />

            <!-- Item 2: User Profile -->
            <LinearLayout
                android:id="@+id/btn_setting_profile"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:gravity="center_vertical"
                android:background="?android:attr/selectableItemBackground">
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="User Profile"
                    android:textColor="@color/discord_text_primary"
                    android:textSize="14sp" />
                    
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/ic_media_play"
                    app:tint="@color/discord_text_muted" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/discord_divider" />

            <!-- Item 3: Voice & Audio -->
            <LinearLayout
                android:id="@+id/btn_setting_voice"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:gravity="center_vertical"
                android:background="?android:attr/selectableItemBackground">
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Voice"
                    android:textColor="@color/discord_text_primary"
                    android:textSize="14sp" />
                    
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/ic_media_play"
                    app:tint="@color/discord_text_muted" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/discord_divider" />

            <!-- Item 4: Appearance / Theme -->
            <LinearLayout
                android:id="@+id/btn_setting_styling"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:gravity="center_vertical"
                android:background="?android:attr/selectableItemBackground">
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Appearance"
                    android:textColor="@color/discord_text_primary"
                    android:textSize="14sp" />
                    
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/ic_media_play"
                    app:tint="@color/discord_text_muted" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/discord_divider" />

            <!-- Item 5: Support -->
            <LinearLayout
                android:id="@+id/btn_setting_support"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:gravity="center_vertical"
                android:background="?android:attr/selectableItemBackground">
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Support"
                    android:textColor="@color/discord_text_primary"
                    android:textSize="14sp" />
                    
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/ic_media_play"
                    app:tint="@color/discord_text_muted" />
            </LinearLayout>
        </LinearLayout>

        <!-- Log Out Button -->
        <Button
            android:id="@+id/btn_logout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="20dp"
            android:text="Log Out"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/discord_red"
            app:layout_constraintTop_toBottomOf="@id/grp_settings"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
