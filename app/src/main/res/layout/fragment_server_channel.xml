<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/discord_dark_base">

    <!-- Left Sidebar (Servers Column) -->
    <LinearLayout
        android:layout_width="72dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/discord_dark_deep"
        android:paddingTop="12dp"
        android:gravity="center_horizontal">

        <!-- Inactive Home / DMs Button (Navigates Back) -->
        <FrameLayout
            android:id="@+id/btn_sidebar_home"
            android:layout_width="72dp"
            android:layout_height="56dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackgroundBorderless">

            <!-- Active Indicator Pill is INVISIBLE on Server screen -->
            <View
                android:layout_width="4dp"
                android:layout_height="36dp"
                android:layout_gravity="start|center_vertical"
                android:background="@android:color/white"
                android:visibility="invisible" />

            <!-- Circular inactive grey container -->
            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_circle_dark"
                android:backgroundTint="@color/discord_dark_alt"
                android:padding="12dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_tab_servers"
                    app:tint="@color/discord_text_muted" />
            </FrameLayout>
        </FrameLayout>

        <!-- Divider separating Home button from other servers -->
        <View
            android:layout_width="32dp"
            android:layout_height="2dp"
            android:layout_gravity="center_horizontal"
            android:background="@color/discord_divider"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <!-- Scrollable Server list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_servers"
            android:layout_width="72dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:clipToPadding="false"
            android:paddingBottom="12dp" />

    </LinearLayout>

    <!-- Right Content Area (Server chat and header) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/discord_dark_main">

        <!-- Discord Premium Chat Toolbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:gravity="center_vertical"
            android:background="@color/discord_dark_main">

            <!-- Drawer Hamburger Menu Icon -->
            <ImageView
                android:id="@+id/btn_menu"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_agenda"
                app:tint="@color/discord_text_muted"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true" />

            <!-- Channel Title & Subtitle Topic -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <TextView
                    android:id="@+id/tv_channel_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="# general-chat"
                    android:textColor="@color/discord_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome to the fantasy world chat!"
                    android:textColor="@color/discord_text_muted"
                    android:textSize="11sp"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>

            <!-- Bell Mute Icon -->
            <ImageView
                android:id="@+id/btn_toolbar_mute"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="8dp"
                android:src="@drawable/ic_tab_notifications"
                app:tint="@color/discord_text_muted"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true" />

            <!-- Pins Icon -->
            <ImageView
                android:id="@+id/btn_toolbar_pins"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_save"
                app:tint="@color/discord_text_muted"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true" />

            <!-- Members List Icon -->
            <ImageView
                android:id="@+id/btn_toolbar_members"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="@color/discord_text_muted"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/discord_divider" />

        <!-- Restyled Voice Call Join Banner -->
        <LinearLayout
            android:id="@+id/banner_voice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="2dp"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:background="@drawable/bg_rounded_deep"
            android:backgroundTint="@color/discord_dark_alt">

            <!-- Active online green indicator -->
            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_circle_red"
                android:backgroundTint="@color/discord_green" />

            <!-- Status texts -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Active Call: General Voice"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4 people currently chatting"
                    android:textColor="@color/discord_text_muted"
                    android:textSize="11sp" />
            </LinearLayout>
                
            <Button
                android:id="@+id/btn_join_voice"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Join"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/discord_green"
                android:textSize="12sp"
                android:textStyle="bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingHorizontal="16dp" />
        </LinearLayout>

        <!-- Chat Messages List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_chat_messages"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingVertical="8dp"
            android:clipToPadding="false" />

        <!-- Restyled Premium Message Input Box -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:gravity="center_vertical"
            android:background="@color/discord_dark_main">

            <!-- Pill Input Box -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="10dp"
                android:background="@drawable/bg_rounded_deep"
                android:backgroundTint="@color/discord_dark_base">

                <!-- Plus attachment circle -->
                <ImageView
                    android:id="@+id/btn_chat_upload"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:padding="4dp"
                    android:src="@android:drawable/ic_menu_add"
                    app:tint="@android:color/white"
                    android:background="@drawable/bg_circle_dark"
                    android:backgroundTint="@color/discord_dark_alt" />

                <!-- Text Input -->
                <EditText
                    android:id="@+id/et_message"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="8dp"
                    android:background="@android:color/transparent"
                    android:hint="Message #general-chat"
                    android:textColorHint="@color/discord_text_muted"
                    android:textColor="@color/discord_text_primary"
                    android:textSize="14sp"
                    android:singleLine="true"
                    android:imeOptions="actionSend" />

                <!-- Emoji Smiley off -->
                <ImageView
                    android:id="@+id/btn_chat_emoji"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:padding="2dp"
                    android:src="@android:drawable/btn_star_big_off"
                    app:tint="@color/discord_text_muted"
                    android:background="?android:attr/selectableItemBackgroundBorderless" />
            </LinearLayout>
                
            <!-- Blurple Send Button -->
            <ImageView
                android:id="@+id/btn_send"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:padding="6dp"
                android:src="@android:drawable/ic_menu_send"
                app:tint="@color/discord_blurple"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
