<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/discord_dark_base">

    <!-- Top Settings Toolbar Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/settings_header"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp"
        android:background="@color/discord_dark_alt"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="10dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/discord_text_primary"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Server Settings"
            android:textColor="@android:color/white"
            android:textSize="17sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp"
            app:layout_constraintStart_toEndOf="@id/btn_back"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/btn_save"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SAVE"
            android:textColor="@color/discord_green"
            android:textSize="14sp"
            android:textStyle="bold"
            android:padding="8dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
        android:id="@+id/toolbar_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/discord_divider"
        app:layout_constraintTop_toBottomOf="@id/settings_header" />

    <!-- Main Content Area Scrollable -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar_divider"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Server Avatar Overlay -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginVertical="16dp">

                <ImageView
                    android:id="@+id/iv_server_avatar"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:src="@drawable/ic_tab_servers"
                    android:background="@drawable/bg_circle_dark"
                    android:backgroundTint="@color/discord_dark_alt"
                    android:padding="20dp" />

                <FrameLayout
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/bg_circle_dark"
                    android:backgroundTint="@color/discord_blurple"
                    android:padding="6dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@android:drawable/ic_menu_camera"
                        app:tint="@android:color/white" />
                </FrameLayout>
            </FrameLayout>

            <!-- Server Name Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_rounded_deep"
                android:backgroundTint="@color/discord_dark_alt">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SERVER NAME"
                    android:textColor="@color/discord_text_muted"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/et_server_name"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="@android:color/transparent"
                    android:text="Fantasy World"
                    android:textColor="@color/discord_text_primary"
                    android:textSize="15sp"
                    android:singleLine="true" />
            </LinearLayout>

            <!-- SERVER SETTINGS SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SERVER SETTINGS"
                android:textColor="@color/discord_text_muted"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_rounded_deep"
                android:backgroundTint="@color/discord_dark_alt">

                <!-- Enable Community -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Enable Community"
                        android:textColor="@color/discord_text_primary"
                        android:textSize="14sp" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_community"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:thumbTint="@android:color/white"
                        app:trackTint="@color/discord_blurple" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/discord_divider" />

                <!-- Discoverable Switch -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Public Server Discovery"
                        android:textColor="@color/discord_text_primary"
                        android:textSize="14sp" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_discovery"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        app:thumbTint="@android:color/white"
                        app:trackTint="@color/discord_blurple" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/discord_divider" />

                <!-- Moderation level selection -->
                <LinearLayout
                    android:id="@+id/btn_moderation"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Verification Level"
                        android:textColor="@color/discord_text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tv_moderation_level"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Medium (Verify Email)"
                        android:textColor="@color/discord_text_muted"
                        android:textSize="13sp"
                        android:layout_marginEnd="6dp" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@android:drawable/arrow_down_float"
                        app:tint="@color/discord_text_muted" />
                </LinearLayout>

            </LinearLayout>

            <!-- USER MANAGEMENT SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="USER MANAGEMENT"
                android:textColor="@color/discord_text_muted"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_rounded_deep"
                android:backgroundTint="@color/discord_dark_alt"
                android:padding="16dp">

                <!-- Roles Label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Roles"
                    android:textColor="@color/discord_text_primary"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <!-- Roles Flow layout containing chips -->
                <com.google.android.material.chip.ChipGroup
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:singleLine="false">

                    <!-- Admin Tag -->
                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👑 Admin"
                        android:textColor="@android:color/white"
                        app:chipBackgroundColor="@color/discord_red"
                        app:chipStrokeWidth="0dp"
                        app:chipCornerRadius="16dp" />

                    <!-- Moderator Tag -->
                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🛡️ Moderator"
                        android:textColor="@android:color/white"
                        app:chipBackgroundColor="@color/discord_green"
                        app:chipStrokeWidth="0dp"
                        app:chipCornerRadius="16dp" />

                    <!-- Nitro Tag -->
                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✨ Nitro Booster"
                        android:textColor="@android:color/white"
                        app:chipBackgroundColor="@color/discord_blurple"
                        app:chipStrokeWidth="0dp"
                        app:chipCornerRadius="16dp" />

                    <!-- Gamer Tag -->
                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎮 Gamer"
                        android:textColor="@android:color/white"
                        app:chipBackgroundColor="@color/discord_divider"
                        app:chipStrokeWidth="0dp"
                        app:chipCornerRadius="16dp" />

                </com.google.android.material.chip.ChipGroup>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/discord_divider"
                    android:layout_marginBottom="12dp" />

                <!-- Bans Row -->
                <LinearLayout
                    android:id="@+id/btn_bans"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Bans"
                        android:textColor="@color/discord_text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 banned users"
                        android:textColor="@color/discord_text_muted"
                        android:textSize="13sp"
                        android:layout_marginEnd="6dp" />

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@android:drawable/ic_menu_gallery"
                        app:tint="@color/discord_text_muted" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
