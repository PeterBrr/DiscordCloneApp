<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_voice_gradient">

    <!-- Header Toolbar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Collapse Button -->
        <ImageView
            android:id="@+id/btn_minimize"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="10dp"
            android:src="@android:drawable/arrow_down_float"
            app:tint="@color/discord_text_primary"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Title & Subtitle Centered -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginHorizontal="16dp"
            app:layout_constraintStart_toEndOf="@id/btn_minimize"
            app:layout_constraintEnd_toStartOf="@+id/btn_speaker_toggle"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/tv_voice_channel_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="General Voice"
                android:textColor="@android:color/white"
                android:textSize="17sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">

                <View
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="@drawable/bg_circle_red"
                    android:backgroundTint="@color/discord_green"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CONNECTED / 00:08"
                    android:textColor="@color/discord_green"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />
            </LinearLayout>
        </LinearLayout>

        <!-- Speaker Select Button -->
        <ImageView
            android:id="@+id/btn_speaker_toggle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:padding="10dp"
            android:src="@drawable/ic_voice_speaker"
            app:tint="@color/discord_text_primary"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintEnd_toStartOf="@+id/btn_chat_shortcut"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Chat Shortcut Button -->
        <ImageView
            android:id="@+id/btn_chat_shortcut"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="10dp"
            android:src="@drawable/ic_voice_chat"
            app:tint="@color/discord_text_primary"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
        android:id="@+id/header_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#15FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/header" />

    <!-- Voice Grid Participants -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_voice_participants"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="10dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/header_divider"
        app:layout_constraintBottom_toTopOf="@id/bottom_dock" />

    <!-- Bottom Controls Floating Dock Panel -->
    <LinearLayout
        android:id="@+id/bottom_dock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingVertical="18dp"
        android:paddingHorizontal="16dp"
        android:background="@drawable/bg_rounded_deep"
        android:backgroundTint="@color/discord_dark_elevated"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 1. Video Camera Toggle -->
        <FrameLayout
            android:id="@+id/btn_video"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginHorizontal="10dp"
            android:background="@drawable/bg_circle_dark"
            android:backgroundTint="@color/discord_dark_base"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackgroundBorderless">

            <ImageView
                android:id="@+id/iv_video_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_voice_video"
                app:tint="@android:color/white" />
        </FrameLayout>

        <!-- 2. Screen Share Toggle -->
        <FrameLayout
            android:id="@+id/btn_screen_share"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginHorizontal="10dp"
            android:background="@drawable/bg_circle_dark"
            android:backgroundTint="@color/discord_dark_base"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackgroundBorderless">

            <ImageView
                android:id="@+id/iv_screen_share_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_voice_screen_share"
                app:tint="@android:color/white" />
        </FrameLayout>

        <!-- 3. Mute Microphone Toggle -->
        <FrameLayout
            android:id="@+id/btn_mute"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginHorizontal="10dp"
            android:background="@drawable/bg_circle_dark"
            android:backgroundTint="@color/discord_dark_base"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackgroundBorderless">

            <ImageView
                android:id="@+id/iv_mute_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_voice_mic"
                app:tint="@android:color/white" />
        </FrameLayout>

        <!-- 4. Deafen Toggle -->
        <FrameLayout
            android:id="@+id/btn_deafen"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginHorizontal="10dp"
            android:background="@drawable/bg_circle_dark"
            android:backgroundTint="@color/discord_dark_base"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackgroundBorderless">

            <ImageView
                android:id="@+id/iv_deafen_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_voice_deafen"
                app:tint="@android:color/white" />
        </FrameLayout>

        <!-- 5. Red Disconnect Button -->
        <FrameLayout
            android:id="@+id/btn_end_call"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:layout_marginHorizontal="10dp"
            android:background="@drawable/bg_circle_red"
            android:backgroundTint="@color/discord_red"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackgroundBorderless">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_voice_disconnect"
                app:tint="@android:color/white" />
        </FrameLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
