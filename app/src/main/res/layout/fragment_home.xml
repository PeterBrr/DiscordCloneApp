<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/discord_dark_base">

    <!-- Server Sidebar -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_servers"
        android:layout_width="72dp"
        android:layout_height="match_parent"
        android:background="@color/discord_dark_deep"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:clipToPadding="false" />

    <!-- Content Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/discord_dark_base">

        <!-- Header -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/discord_dark_base"
            android:paddingHorizontal="16dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:text="Messages"
                android:textColor="@color/discord_text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />
                
            <ImageView
                android:id="@+id/btn_add_friend"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center_vertical|end"
                android:src="@android:drawable/ic_menu_add"
                app:tint="@color/discord_text_muted"
                xmlns:app="http://schemas.android.com/apk/res-auto" />
        </FrameLayout>

        <!-- Direct Messages List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_direct_messages"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingTop="8dp"
            android:clipToPadding="false" />

    </LinearLayout>

</LinearLayout>
