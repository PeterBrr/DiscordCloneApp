<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/nav_login">

    <fragment
        android:id="@+id/nav_login"
        android:name="com.example.clonediscordapp.ui.auth.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_login_to_home"
            app:destination="@id/nav_home"
            app:popUpTo="@id/nav_login"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_login_to_register"
            app:destination="@id/nav_register" />
    </fragment>

    <fragment
        android:id="@+id/nav_register"
        android:name="com.example.clonediscordapp.ui.auth.RegisterFragment"
        android:label="Register"
        tools:layout="@layout/fragment_register">
        <action
            android:id="@+id/action_register_to_home"
            app:destination="@id/nav_home"
            app:popUpTo="@id/nav_login"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_register_to_login"
            app:destination="@id/nav_login"
            app:popUpTo="@id/nav_login"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/nav_home"
        android:name="com.example.clonediscordapp.ui.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_server"
            app:destination="@id/nav_server" />
    </fragment>
    
    <fragment
        android:id="@+id/nav_server"
        android:name="com.example.clonediscordapp.ui.server.ServerChannelFragment"
        android:label="Server"
        tools:layout="@layout/fragment_server_channel">
        <action
            android:id="@+id/action_server_to_voice"
            app:destination="@id/nav_voice" />
        <action
            android:id="@+id/action_server_to_settings"
            app:destination="@id/nav_server_settings" />
        <action
            android:id="@+id/action_server_to_channel_settings"
            app:destination="@id/nav_channel_settings" />
    </fragment>

    <fragment
        android:id="@+id/nav_voice"
        android:name="com.example.clonediscordapp.ui.voice.VoiceCallFragment"
        android:label="Voice"
        tools:layout="@layout/fragment_voice_call" />

    <fragment
        android:id="@+id/nav_notifications"
        android:name="com.example.clonediscordapp.ui.notifications.NotificationsFragment"
        tools:layout="@layout/fragment_notifications" />

    <fragment
        android:id="@+id/nav_profile"
        android:name="com.example.clonediscordapp.ui.profile.ProfileFragment"
        tools:layout="@layout/fragment_profile" />

    <fragment
        android:id="@+id/nav_server_settings"
        android:name="com.example.clonediscordapp.ui.server.ServerSettingsFragment"
        android:label="Server Settings"
        tools:layout="@layout/fragment_server_settings" />

    <fragment
        android:id="@+id/nav_channel_settings"
        android:name="com.example.clonediscordapp.ui.server.ChannelSettingsFragment"
        android:label="Channel Settings"
        tools:layout="@layout/fragment_channel_settings" />

</navigation>
